{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/outbound",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/outbound-send",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/gmail-watch",
      "schedule": "0 0 */6 * *"
    },
    {
      "path": "/api/email/ingest",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/knowledge/index?reindex=1",
      "schedule": "0 18 * * *"
    }
  ]
}
